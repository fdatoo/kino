---
source: crates/kino-transcode/src/encoder/qsv.rs
expression: "format!(\"{command}\")"
---
ffmpeg -hide_banner -nostdin -loglevel warning -progress pipe:1 -hwaccel qsv -hwaccel_output_format qsv -i '/library/Some Movie/source.mkv' -map 0:v:0 -c:v hevc_qsv -global_quality 24 -preset medium -pix_fmt qsv -color_primaries bt709 -color_trc bt709 -colorspace bt709 -vf 'vpp_qsv=tonemap=1:format=nv12,vpp_qsv=w=1920:h=1080' -map '0:a:0?' -c:a aac -ac 2 -b:a 192k -f hls -hls_segment_type fmp4 -hls_time 6 -hls_playlist_type vod -hls_segment_filename '/library/Some Movie/transcodes/qsv-hevc-1080p-tonemap/seg-%05d.m4s' -hls_fmp4_init_filename init.mp4 '/library/Some Movie/transcodes/qsv-hevc-1080p-tonemap/media.m3u8'
