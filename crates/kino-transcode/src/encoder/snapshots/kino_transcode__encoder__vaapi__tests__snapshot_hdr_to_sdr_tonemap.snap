---
source: crates/kino-transcode/src/encoder/vaapi.rs
expression: "format!(\"{command}\")"
---
ffmpeg -hide_banner -nostdin -loglevel warning -progress pipe:1 -init_hw_device 'vaapi=hw:/dev/dri/renderD128' -filter_hw_device hw -hwaccel vaapi -hwaccel_output_format vaapi -i '/library/Some Movie/source.mkv' -map 0:v:0 -c:v hevc_vaapi -qp 24 -pix_fmt vaapi -color_primaries bt709 -color_trc bt709 -colorspace bt709 -vf 'hwdownload,format=p010le,zscale=t=linear:npl=100,format=gbrpf32le,zscale=p=bt709,tonemap=tonemap=hable:desat=0,zscale=t=bt709:m=bt709:r=tv,format=nv12,hwupload,scale_vaapi=w=1920:h=1080' -map '0:a:0?' -c:a aac -ac 2 -b:a 192k -f hls -hls_segment_type fmp4 -hls_time 6 -hls_playlist_type vod -hls_segment_filename '/library/Some Movie/transcodes/vaapi-hevc-1080p-tonemap/seg-%05d.m4s' -hls_fmp4_init_filename init.mp4 '/library/Some Movie/transcodes/vaapi-hevc-1080p-tonemap/media.m3u8'
