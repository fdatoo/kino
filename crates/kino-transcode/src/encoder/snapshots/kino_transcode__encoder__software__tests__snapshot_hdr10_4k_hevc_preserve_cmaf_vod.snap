---
source: crates/kino-transcode/src/encoder/software.rs
expression: "format!(\"{command}\")"
---
ffmpeg -hide_banner -nostdin -loglevel warning -progress pipe:1 -i '/library/Some Movie/source.mkv' -map 0:v:0 -c:v libx265 -crf 20 -preset slow -pix_fmt yuv420p10le -color_primaries bt2020 -color_trc smpte2084 -colorspace bt2020nc -x265-params 'master-display=G(13250,34500)B(7500,3000)R(34000,16000)WP(15635,16450)L(10000000,50):max-cll=1000,400' -map '0:a:0?' -c:a aac -ac 2 -b:a 256k -f hls -hls_segment_type fmp4 -hls_time 6 -hls_playlist_type vod -hls_segment_filename '/library/Some Movie/transcodes/hevc-4k-hdr10/seg-%05d.m4s' -hls_fmp4_init_filename init.mp4 '/library/Some Movie/transcodes/hevc-4k-hdr10/media.m3u8'
