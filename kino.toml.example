# Path to the SQLite database file. Required.
database_path = "/var/lib/kino/kino.db"

# Root directory of the on-disk media library. Required.
library_root = "/srv/media"

# Logging filter. Optional. Defaults to "info".
# Accepts any tracing-subscriber EnvFilter expression.
# Runtime overrides: RUST_LOG, then KINO_LOG, then this value.
log_level = "info"

# Logging output format. Optional. Defaults to "pretty".
# Use "json" for newline-delimited production logs.
log_format = "pretty"

[library]
# How canonical layout placement handles source files. Optional. Defaults to
# "hard_link" to preserve the original source path. Use "move" to rename the
# source into the library.
# Runtime override: KINO_LIBRARY__CANONICAL_TRANSFER.
canonical_transfer = "hard_link"

# Directory used for content-addressed artwork caching. Optional. Defaults to
# <library_root>/.kino/artwork.
# Runtime override: KINO_LIBRARY__ARTWORK_CACHE_DIR.
# artwork_cache_dir = "/srv/media/.kino/artwork"

# Directory used for image-subtitle OCR staging. Optional. Defaults to
# <library_root>/.kino/subtitles.
# Runtime override: KINO_LIBRARY__SUBTITLE_STAGING_DIR.
# subtitle_staging_dir = "/srv/media/.kino/subtitles"

[server]
# Address the server binds to. Optional. Defaults to 127.0.0.1:7777.
listen = "127.0.0.1:7777"

# Public base URL advertised in generated OpenAPI documents. Optional.
# Defaults to http://127.0.0.1:8080.
# Runtime override: KINO_SERVER__PUBLIC_BASE_URL.
public_base_url = "http://127.0.0.1:8080"

# Browser origins allowed to call the API. Optional. Empty permits all origins
# for non-credentialed requests.
# Runtime override: KINO_SERVER__CORS_ALLOWED_ORIGINS.
cors_allowed_origins = []

[server.discovery]
# Advertise this server on the LAN with Bonjour/mDNS. Optional. Defaults to true.
# Runtime override: KINO_SERVER__DISCOVERY__ENABLED.
enabled = true

# Bonjour service instance name. Optional. Defaults to the system hostname.
# Runtime override: KINO_SERVER__DISCOVERY__INSTANCE_NAME.
# instance_name = "your hostname here"

[server.session_reaper]
# Seconds between playback session reaper sweeps. Optional. Defaults to 30.
# Runtime override: KINO_SERVER__SESSION_REAPER__TICK_SECONDS.
tick_seconds = 30

# Seconds after which active playback sessions become idle. Optional. Defaults
# to 60.
# Runtime override: KINO_SERVER__SESSION_REAPER__ACTIVE_TO_IDLE_SECONDS.
active_to_idle_seconds = 60

# Seconds after which idle playback sessions become ended. Optional. Defaults
# to 300.
# Runtime override: KINO_SERVER__SESSION_REAPER__IDLE_TO_ENDED_SECONDS.
idle_to_ended_seconds = 300

[server.pairing_reaper]
# Seconds between pairing reaper sweeps. Optional. Defaults to 60.
# Runtime override: KINO_SERVER__PAIRING_REAPER__TICK_SECONDS.
tick_seconds = 60

# Seconds after which terminal pairing rows are deleted. Optional. Defaults to
# 86400.
# Runtime override: KINO_SERVER__PAIRING_REAPER__RETENTION_SECONDS.
retention_seconds = 86400

[tmdb]
# TMDB v3 API key. Optional until request resolution is enabled.
# Runtime override: KINO_TMDB__API_KEY.
# api_key = "replace-me"

# Polite client-side request cap. Optional. Defaults to 20, maximum 50.
# Runtime override: KINO_TMDB__MAX_REQUESTS_PER_SECOND.
max_requests_per_second = 20

[ocr]
# Tesseract binary path. Optional. Defaults to resolving "tesseract" on PATH.
# Runtime override: KINO_OCR__TESSERACT_PATH.
tesseract_path = "tesseract"

# Tesseract language code. Optional. Defaults to "eng".
# Runtime override: KINO_OCR__LANGUAGE.
language = "eng"

[transcode]

[transcode.policy]
# High-quality variant codec. Optional. Defaults to "hevc".
# Runtime override: KINO_TRANSCODE__POLICY__HIGH__CODEC.
high.codec = "hevc"

# High-quality variant bit depth. Optional. Defaults to 10.
# Runtime override: KINO_TRANSCODE__POLICY__HIGH__BIT_DEPTH.
high.bit_depth = 10

# High-quality variant VMAF target. Optional. Defaults to 95.
# Runtime override: KINO_TRANSCODE__POLICY__HIGH__VMAF_TARGET.
high.vmaf_target = 95

# High-quality variant encoder preset key. Optional. Defaults to "medium".
# Runtime override: KINO_TRANSCODE__POLICY__HIGH__PRESET.
high.preset = "medium"

# Compatibility variant codec. Optional. Defaults to "h264".
# Runtime override: KINO_TRANSCODE__POLICY__COMPAT__CODEC.
compat.codec = "h264"

# Compatibility variant VMAF target. Optional. Defaults to 90.
# Runtime override: KINO_TRANSCODE__POLICY__COMPAT__VMAF_TARGET.
compat.vmaf_target = 90

# Compatibility variant maximum height. Optional. Defaults to 1080.
# Runtime override: KINO_TRANSCODE__POLICY__COMPAT__MAX_HEIGHT.
compat.max_height = 1080

[transcode.scheduler]
# Scheduler dispatch tick interval in milliseconds. Optional. Defaults to 250.
# Runtime override: KINO_TRANSCODE__SCHEDULER__TICK_MILLIS.
tick_millis = 250

# Maximum job attempts before terminal failure. Optional. Defaults to 3.
# Runtime override: KINO_TRANSCODE__SCHEDULER__MAX_ATTEMPTS.
max_attempts = 3

# Retry backoff for transient failures in seconds. Optional. Defaults to 60.
# Runtime override: KINO_TRANSCODE__SCHEDULER__BACKOFF_SECONDS.
backoff_seconds = 60

# Lane reserved for live transcodes. Optional. Defaults to "cpu".
# Runtime override: KINO_TRANSCODE__SCHEDULER__RESERVE_LIVE_LANE.
reserve_live_lane = "cpu"

# Reset running jobs to planned on startup. Optional. Defaults to true.
# Runtime override: KINO_TRANSCODE__SCHEDULER__RECOVERY_ON_BOOT.
recovery_on_boot = true

[transcode.ephemeral]
# Allow starting new on-the-fly live encodes. Existing cached and durable hits
# still serve when disabled. Optional. Defaults to true.
# Runtime override: KINO_TRANSCODE__EPHEMERAL__ENABLED.
enabled = true

# Directory used for short-lived live encode outputs. Optional. Defaults to
# <library_root>/.kino/ephemeral.
# Runtime override: KINO_TRANSCODE__EPHEMERAL__CACHE_ROOT.
cache_root = "/srv/media/.kino/ephemeral"

# Maximum total ephemeral cache size in bytes. Optional. Defaults to 25 GiB.
# Runtime override: KINO_TRANSCODE__EPHEMERAL__MAX_SIZE_BYTES.
max_size_bytes = 26843545600

# Seconds since last access before an ephemeral output is evicted. Optional.
# Defaults to 21600.
# Runtime override: KINO_TRANSCODE__EPHEMERAL__MAX_AGE_SECONDS.
max_age_seconds = 21600

# Seconds between eviction sweeps. Optional. Defaults to 60.
# Runtime override: KINO_TRANSCODE__EPHEMERAL__EVICTION_TICK_SECONDS.
eviction_tick_seconds = 60

[providers.disc_rip]
# Directory scanned for MakeMKV-style output files. Required when this provider
# section is present, and validated at startup.
# Runtime override: KINO_PROVIDERS__DISC_RIP__PATH.
path = "/srv/kino/rips"

# Provider ranking preference. Optional. Defaults to 0.
# Runtime override: KINO_PROVIDERS__DISC_RIP__PREFERENCE.
preference = 0

[providers.watch_folder]
# Directory watched for user-supplied media files. Required when this provider
# section is present, and validated at startup.
# Runtime override: KINO_PROVIDERS__WATCH_FOLDER__PATH.
path = "/srv/kino/incoming"

# Provider ranking preference. Optional. Defaults to 0.
# Runtime override: KINO_PROVIDERS__WATCH_FOLDER__PREFERENCE.
preference = 0

# Seconds file size must remain unchanged before ingestion. Optional. Defaults
# to 5.
# Runtime override: KINO_PROVIDERS__WATCH_FOLDER__STABILITY_SECONDS.
stability_seconds = 5
